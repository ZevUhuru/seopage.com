# ─────────────────────────────────────────────────────────────
# SEOPage MVP — environment
# Copy this file to .env.local and fill in your own keys.
# Never commit .env.local (it's gitignored).
# ─────────────────────────────────────────────────────────────

# Anthropic — powers the generation pipeline (Claude Opus 4.8).
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Stripe — hosted Checkout for the $29 unlock.
# Test keys at https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# From your webhook endpoint (optional locally — see README). Use `stripe listen`.
STRIPE_WEBHOOK_SECRET=whsec_...

# Public origin used to build Stripe redirect URLs.
# Local: http://localhost:3000   Prod: https://seopage.com
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Shared store for generations (REQUIRED in production on Vercel — serverless
# instances don't share memory). Provision via Vercel → Storage → Upstash (Redis);
# it auto-injects these. Locally you can leave them blank (a temp-file fallback runs).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Admin order/intake lookup at /admin?key=<this>. Use a long random string.
# Leave unset to keep the page locked (it fails closed).
ADMIN_TOKEN=

